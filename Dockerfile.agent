FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    langchain>=1.3.0 \
    langgraph>=1.2.0 \
    langgraph-prebuilt>=1.1.0 \
    langchain-openrouter>=0.2.0 \
    clickhouse-connect>=1.0.0 \
    structlog>=24.0.0 \
    httpx>=0.27.0 \
    fastapi>=0.115.0 \
    uvicorn>=0.34.0

COPY src/ src/

ENV PYTHONPATH=/app

EXPOSE 8000 8001

CMD ["python", "-m", "src.agent.server"]
